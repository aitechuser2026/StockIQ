# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Financial Modeling Prep ──────────────────────────────────────────────────
# Free key (250 req/day, no credit card): https://financialmodelingprep.com/developer/docs
# Powers the StockDeepDive page (price, PE, quarterly revenue/margins)
FMP_KEY=your_fmp_api_key_here

# ─── Instructions ─────────────────────────────────────────────────────────────
# 1. Copy this file to .env  (cp .env.example .env)
# 2. Fill in your Supabase URL/key and FMP key
# 3. Never commit .env to git — it's in .gitignore
